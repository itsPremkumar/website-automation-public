# ── GitHub Credentials ──────────────────────────────────────────────
# Generate a token: https://github.com/settings/tokens
# Required scope: 'repo' (full control of repos). 'delete_repo' optional.
# IMPORTANT: this file is safe to commit. NEVER put a real token in it.
# Copy it to '.env' (which is git-ignored) and fill in YOUR values.
GITHUB_USERNAME=your_github_username_here
GITHUB_TOKEN=ghp_your_personal_access_token_here

# ── Site Configuration ───────────────────────────────────────────────
# Base folder for all sites (default: ./sites relative to project root)
SITES_DIR=sites
